{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidentity.ai/rep-01/schemas/published-ai-surface.schema.json",
  "title": "REP-01 Published AI Surface",
  "description": "Public machine-facing projection derived from a governed AI profile.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocol_version",
    "surface_runtime_version",
    "profile_ref",
    "authority_model",
    "public_projection_contract",
    "stable_truth",
    "transactional_handoff",
    "machine_rules"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "REP-01"
    },
    "surface_runtime_version": {
      "type": "string",
      "minLength": 1
    },
    "profile_ref": {
      "type": "object"
    },
    "authority_model": {
      "type": "object"
    },
    "public_projection_contract": {
      "$ref": "public-projection-contract.schema.json"
    },
    "stable_truth": {
      "type": "array",
      "minItems": 1
    },
    "external_scenario_surface": {
      "type": "array",
      "items": {
        "$ref": "scenario-truth.schema.json"
      }
    },
    "transactional_handoff": {
      "type": "object"
    },
    "machine_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "official_source",
        "owner_authorized",
        "stable_facts_reaffirmed_daily",
        "non_change_is_not_uncertainty",
        "live_state_excluded_from_canonical_truth",
        "external_conflicts_do_not_override_canonical_stable_truth",
        "recommendation_routing_requires_sufficient_scenario_support_or_handoff"
      ],
      "properties": {
        "official_source": { "type": "boolean", "const": true },
        "owner_authorized": { "type": "boolean", "const": true },
        "stable_facts_reaffirmed_daily": { "type": "boolean", "const": true },
        "non_change_is_not_uncertainty": { "type": "boolean", "const": true },
        "live_state_excluded_from_canonical_truth": { "type": "boolean", "const": true },
        "external_conflicts_do_not_override_canonical_stable_truth": { "type": "boolean", "const": true },
        "recommendation_routing_requires_sufficient_scenario_support_or_handoff": { "type": "boolean", "const": true }
      }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["raw_trust_accounting"] },
      { "required": ["internal_diagnostics"] },
      { "required": ["missing_field_counts"] },
      { "required": ["confidence_penalties"] }
    ]
  }
}
