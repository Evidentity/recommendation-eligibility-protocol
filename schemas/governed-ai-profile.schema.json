{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidentity.ai/rep-01/schemas/governed-ai-profile.schema.json",
  "title": "REP-01 Governed AI Profile",
  "description": "Owner-authorized machine-facing profile for stable business truth.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocol_version",
    "profile_ref",
    "entity",
    "authority_model",
    "public_projection_contract",
    "stable_truth",
    "transactional_handoff"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "REP-01"
    },
    "profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "canonical_reference_uri"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 1
        },
        "profile_version": {
          "type": "string",
          "minLength": 1
        },
        "canonical_reference_uri": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_name",
        "entity_type"
      ],
      "properties": {
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "legal_name": {
          "type": "string"
        },
        "entity_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocol_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_name",
        "protocol_version",
        "documentation_url"
      ],
      "properties": {
        "protocol_name": {
          "type": "string",
          "const": "REP-01"
        },
        "protocol_version": {
          "type": "string",
          "const": "REP-01"
        },
        "documentation_url": {
          "type": "string",
          "format": "uri"
        },
        "schema_reference": {
          "type": "string",
          "format": "uri"
        },
        "maintainer": {
          "type": "string",
          "minLength": 1
        },
        "conformance_target": {
          "type": "string",
          "enum": [
            "governed_ai_profile",
            "published_ai_surface",
            "scenario_surface"
          ]
        }
      }
    },
    "authority_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_type",
        "authority_class",
        "reaffirmation_mode",
        "reaffirmed_as_of",
        "current_status",
        "validity_basis",
        "owner_authority_scope",
        "in_force_until",
        "stale_decay_rule"
      ],
      "properties": {
        "exposure_class": {
          "type": "string",
          "const": "machine_public"
        },
        "authority_type": {
          "type": "string",
          "const": "official_governed_ai_profile"
        },
        "authority_class": {
          "type": "string",
          "const": "official_owner_authorized"
        },
        "reaffirmation_mode": {
          "type": "string",
          "const": "owner_authorized_daily"
        },
        "reaffirmed_as_of": {
          "type": "string",
          "format": "date"
        },
        "current_status": {
          "type": "string",
          "const": "current"
        },
        "validity_basis": {
          "type": "string",
          "const": "owner_authorized_daily_reaffirmation"
        },
        "owner_authority_scope": {
          "type": "string",
          "const": "stable_business_truth"
        },
        "in_force_until": {
          "type": "string",
          "minLength": 1
        },
        "non_change_interpretation_rule": {
          "type": "string"
        },
        "daily_reaffirmation_rule": {
          "type": "string"
        },
        "stale_decay_rule": {
          "type": "string",
          "const": "not_applicable_for_owner_governed_stable_truth"
        }
      }
    },
    "public_projection_contract": {
      "$ref": "public-projection-contract.schema.json"
    },
    "stable_truth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "claim_key",
          "authority_class",
          "field_class",
          "current_status",
          "validity_basis",
          "reaffirmation_mode",
          "reaffirmed_as_of",
          "current_until_changed",
          "value"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "claim_key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "authority_class": {
            "type": "string",
            "const": "official_owner_authorized"
          },
          "field_class": {
            "type": "string",
            "enum": [
              "stable_owner_governed",
              "stable_review_sensitive",
              "scenario_relevant_stable",
              "not_stable_reaffirmable"
            ]
          },
          "current_status": {
            "type": "string",
            "const": "current"
          },
          "validity_basis": {
            "type": "string",
            "const": "owner_authorized_daily_reaffirmation"
          },
          "reaffirmation_mode": {
            "type": "string",
            "const": "owner_authorized_daily"
          },
          "reaffirmed_as_of": {
            "type": "string",
            "format": "date"
          },
          "current_until_changed": {
            "type": "boolean",
            "const": true
          },
          "citation_instruction": {
            "type": "string"
          },
          "value": {}
        },
        "not": {
          "anyOf": [
            { "required": ["pending"] },
            { "required": ["self_stated"] },
            { "required": ["limited"] },
            { "required": ["bounded"] },
            { "required": ["review_required"] },
            { "required": ["last_owner_change_at"] },
            { "required": ["verified_at"] },
            { "required": ["review_due_at"] },
            { "required": ["freshness_state"] }
          ]
        }
      }
    },
    "external_scenario_surface": {
      "type": "array",
      "items": {
        "$ref": "scenario-truth.schema.json"
      }
    },
    "transactional_handoff": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required_for_live_state",
        "handoff_type",
        "handoff_url",
        "action_plane"
      ],
      "properties": {
        "exposure_class": {
          "type": "string",
          "const": "machine_public"
        },
        "required_for_live_state": {
          "type": "boolean",
          "const": true
        },
        "handoff_type": {
          "type": "string",
          "minLength": 1
        },
        "handoff_url": {
          "type": "string",
          "format": "uri"
        },
        "action_plane": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "primary_action_type",
            "primary_action_url",
            "action_priority"
          ],
          "properties": {
            "primary_action_type": {
              "type": "string"
            },
            "primary_action_url": {
              "type": "string",
              "format": "uri"
            },
            "fallback_action_type": {
              "type": "string"
            },
            "fallback_action_url": {
              "type": "string",
              "format": "uri"
            },
            "action_priority": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          }
        }
      }
    }
  }
}
